{% extends 'admin/base.html.twig' %}

{% block title %}Gestion des avis{% endblock %}

{% block body %}
    <div class="row mb-4">
        <div class="col-md-12">
            <h1>Gestion des avis</h1>
            <a href="{{ path('admin_index') }}" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Tableau de bord principal
            </a>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {% for message in app.flashes('info') %}
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {# AVIS EN ATTENTE #}
    {% set avisEnAttente = avis|filter(a => not a.approuve) %}
    {% if avisEnAttente|length > 0 %}
        <div class="card mb-4 border-warning">
            <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="bi bi-exclamation-triangle"></i>
                    Avis en attente ({{ avisEnAttente|length }})
                </h5>
                <div id="bulk-actions-attente" style="display:none;">
                    <span id="count-attente" class="me-2">0 sélectionné(s)</span>
                    <button type="button" class="btn btn-danger btn-sm" id="btn-delete-attente">
                        <i class="bi bi-trash"></i> Supprimer la sélection
                    </button>
                </div>
            </div>
            <div class="card-body">
                <form id="form-attente" method="post" action="{{ path('admin_avis_delete_bulk') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_bulk_avis') }}">
                    <table class="table table-hover">
                        <thead>
                        <tr>
                            <th><input type="checkbox" class="select-all-attente" title="Tout sélectionner"></th>
                            <th>Auteur</th>
                            <th>Email</th>
                            <th>Note</th>
                            <th>Contenu</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for avi in avisEnAttente %}
                            <tr class="table-warning">
                                <td><input type="checkbox" name="ids[]" value="{{ avi.id }}" class="cb-attente"></td>
                                <td>{{ avi.nom }}</td>
                                <td>
                                    {% if avi.email %}
                                        <a href="mailto:{{ avi.email }}" class="text-decoration-none">
                                            <i class="bi bi-envelope"></i> {{ avi.email }}
                                        </a>
                                    {% else %}
                                        <span class="text-muted fst-italic">Non renseigné</span>
                                    {% endif %}
                                </td>
                                <td><span class="text-warning">{% for i in 1..avi.note %}🍓{% endfor %}</span></td>
                                <td>{{ avi.commentaire|length > 80 ? avi.commentaire|slice(0, 80) ~ '...' : avi.commentaire }}</td>
                                <td>{{ avi.dateCreation|date('d/m/Y H:i') }}</td>
                                <td>
                                    {# CORRECTION : plus de <form> imbriqué — on utilise des boutons data-* #}
                                    <button type="button"
                                            class="btn btn-sm btn-success"
                                            data-bs-toggle="modal"
                                            data-bs-target="#modalAvis"
                                            data-nom="{{ avi.nom }}"
                                            data-note="{{ avi.note }}"
                                            data-commentaire="{{ avi.commentaire|e('html_attr') }}"
                                            data-action="{{ path('admin_avis_valider', {id: avi.id}) }}"
                                            data-token="{{ csrf_token('valider_' ~ avi.id) }}">
                                        <i class="bi bi-eye"></i> Valider
                                    </button>
                                    <button type="button"
                                            class="btn btn-sm btn-danger btn-action-avis"
                                            data-action="{{ path('admin_avis_delete', {id: avi.id}) }}"
                                            data-token="{{ csrf_token('delete_' ~ avi.id) }}"
                                            data-confirm="Supprimer cet avis ?">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </form>
            </div>
        </div>
    {% endif %}

    {# MODALE DE PRÉVISUALISATION #}
    <div class="modal fade" id="modalAvis" tabindex="-1" aria-labelledby="modalAvisLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title" id="modalAvisLabel">Lire l&#39;avis avant validation</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p><strong>Auteur :</strong> <span id="modal-nom"></span></p>
                    <p><strong>Note :</strong> <span id="modal-note"></span></p>
                    <hr>
                    <p id="modal-commentaire" class="fs-5"></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button>
                    <form id="modal-form-valider" method="post">
                        <input type="hidden" name="_token" id="modal-token">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle"></i> Confirmer la validation
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    {# AVIS VALIDÉS #}
    {% set avisValides = avis|filter(a => a.approuve) %}
    <div class="card">
        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                <i class="bi bi-check-circle"></i>
                Avis validés ({{ avisValides|length }})
            </h5>
            <div id="bulk-actions-valides" style="display:none;">
                <span id="count-valides" class="me-2">0 sélectionné(s)</span>
                <button type="button" class="btn btn-danger btn-sm" id="btn-delete-valides">
                    <i class="bi bi-trash"></i> Supprimer la sélection
                </button>
            </div>
        </div>
        <div class="card-body">
            <form id="form-valides" method="post" action="{{ path('admin_avis_delete_bulk') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_bulk_avis') }}">
                <table class="table table-hover">
                    <thead>
                    <tr>
                        <th><input type="checkbox" class="select-all-valides" title="Tout sélectionner"></th>
                        <th>ID</th>
                        <th>Auteur</th>
                        <th>Email</th>
                        <th>Note</th>
                        <th>Contenu</th>
                        <th>Date</th>
                        <th>Réponse</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for avi in avisValides %}
                        <tr>
                            <td><input type="checkbox" name="ids[]" value="{{ avi.id }}" class="cb-valides"></td>
                            <td>{{ loop.index }}</td>
                            <td>{{ avi.nom }}</td>
                            <td>
                                {% if avi.email %}
                                    <a href="mailto:{{ avi.email }}" class="text-decoration-none">
                                        <i class="bi bi-envelope"></i> {{ avi.email }}
                                    </a>
                                {% else %}
                                    <span class="text-muted fst-italic">Non renseigné</span>
                                {% endif %}
                            </td>
                            <td><span class="text-warning">{% for i in 1..avi.note %}🍓{% endfor %}</span></td>
                            <td>{{ avi.commentaire|length > 80 ? avi.commentaire|slice(0, 80) ~ '...' : avi.commentaire }}</td>
                            <td>{{ avi.dateCreation|date('d/m/Y H:i') }}</td>
                            <td>
                                {% if avi.hasReponse %}
                                    <span class="badge bg-info"><i class="bi bi-reply-fill"></i> Répondu</span>
                                {% else %}
                                    <span class="badge bg-secondary"><i class="bi bi-reply"></i> Sans réponse</span>
                                {% endif %}
                            </td>
                            <td>
                                <a href="{{ path('admin_avisEdit', {id: avi.id}) }}" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil"></i> Répondre
                                </a>
                                {# CORRECTION : plus de <form> imbriqué — on utilise des boutons data-* #}
                                <button type="button"
                                        class="btn btn-sm btn-warning btn-action-avis"
                                        data-action="{{ path('admin_avis_valider', {id: avi.id}) }}"
                                        data-token="{{ csrf_token('valider_' ~ avi.id) }}"
                                        data-confirm="Retirer cet avis ?">
                                    <i class="bi bi-x-circle"></i>
                                </button>
                                <button type="button"
                                        class="btn btn-sm btn-danger btn-action-avis"
                                        data-action="{{ path('admin_avis_delete', {id: avi.id}) }}"
                                        data-token="{{ csrf_token('delete_' ~ avi.id) }}"
                                        data-confirm="Supprimer cet avis ?">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="9" class="text-center">Aucun avis validé</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </form>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/script.js') }}"></script>
{% endblock %}
